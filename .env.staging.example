# ─── Copy this to Vercel → Settings → Environment Variables ────────────────
# All values below are REQUIRED unless marked optional.

# ─── App ───────────────────────────────────────────────────────────────────
NEXTAUTH_URL=https://stage.eagledrop.net
NEXTAUTH_SECRET=replace-with-output-of--openssl-rand-base64-32

# ─── Database (Neon PostgreSQL) ────────────────────────────────────────────
# Get both URLs from your Neon project → Connection Details
# "Pooled connection" → DATABASE_URL
# "Direct connection" → DATABASE_URL_UNPOOLED
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Email (use Resend — free 3,000 emails/month) ─────────────────────────
# Sign up at resend.com → API Keys → Create key
# Verify your domain (eagledrop.net) in Resend → Domains
EMAIL_FROM=FIFAFun 2026 <noreply@eagledrop.net>
EMAIL_SERVER_HOST=smtp.resend.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=resend
EMAIL_SERVER_PASSWORD=re_xxxxxxxxxxxxxxxxxxxx

# ─── Admin ─────────────────────────────────────────────────────────────────
ADMIN_EMAIL=your-admin-email@gmail.com

# ─── Score sync (optional — leave blank to skip auto-sync) ────────────────
# Register free at https://www.football-data.org
FOOTBALL_DATA_API_KEY=

# ─── Cron secret (protects /api/sync-scores) ──────────────────────────────
CRON_SECRET=replace-with-random-string-32-chars
