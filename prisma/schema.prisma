generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ──────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String                          // full real name (admin only)
  email         String    @unique
  username      String?   @unique               // login username
  nickname      String    @default("")          // public display name
  league        String    @default("")          // league name string (sync with League.name)
  leagueId      Int?                            // FK to League table
  cheeringFrom  String    @default("")          // country/city (optional)
  password      String
  role          String    @default("player")    // "player" | "admin"
  status        String    @default("pending")   // "pending" | "verified" | "approved" | "denied"
  verifyToken   String?
  verifyExpiry  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  predictions   Prediction[]
  sessions      Session[]
  leagueRel     League?       @relation(fields: [leagueId], references: [id])
  bonusAnswers      BonusAnswer[]
  pollVotes         PollVote[]
  auditLogs         AuditLog[]
  shoutboxMessages  ShoutboxMessage[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Leagues ───────────────────────────────────────────────

model League {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  slug      String   @unique
  color     String   @default("#1e3a5f")       // hex color for league card
  createdAt DateTime @default(now())
  users     User[]
}

// ─── Tournament ────────────────────────────────────────────

model Team {
  id        Int    @id @default(autoincrement())
  name      String
  code      String @unique  // 3-letter code e.g. "USA", "BRA"
  flagCode  String @default("") // 2-letter ISO code e.g. "us", "br"
  group     String          // "A"–"L" for WC2026
  flag      String @default("")  // kept for backward compat

  homeMatches Match[] @relation("HomeTeam")
  awayMatches Match[] @relation("AwayTeam")
}

model Match {
  id          Int       @id @default(autoincrement())
  homeTeamId  Int
  awayTeamId  Int
  group       String    // "A"-"L" or "R32","R16","QF","SF","3rd","F"
  stage       String    @default("group") // "group" | "knockout"
  matchDate   DateTime
  venue       String    @default("")
  homeScore   Int?
  awayScore   Int?
  status      String    @default("upcoming") // "upcoming" | "live" | "finished"
  locked      Boolean   @default(false)       // predictions locked when true
  externalId  String?   @unique               // ID from football-data.org API

  homeTeam    Team      @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team      @relation("AwayTeam", fields: [awayTeamId], references: [id])
  predictions Prediction[]
  polls       Poll[]
}

model Prediction {
  id          Int      @id @default(autoincrement())
  userId      String
  matchId     Int
  homeScore   Int
  awayScore   Int
  joker       Boolean  @default(false)   // ×2 multiplier
  points      Int?                        // null until match finished & scored
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

// ─── Bonus Questions ───────────────────────────────────────

model BonusQuestion {
  id           Int      @id @default(autoincrement())
  question     String
  type         String   @default("single")     // "single" | "multiple"
  stage        String   @default("group")       // "group" | "knockout" | "final"
  options      String   @default("[]")          // JSON array of option strings
  correctAnswer String? @default("")            // set when answered
  points       Int      @default(5)
  status       String   @default("open")        // "open" | "closed" | "answered"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  answers      BonusAnswer[]
}

model BonusAnswer {
  id           Int      @id @default(autoincrement())
  userId       String
  questionId   Int
  answer       String
  points       Int?
  createdAt    DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  question     BonusQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

// ─── Audience Polls ────────────────────────────────────────

model Poll {
  id        Int      @id @default(autoincrement())
  matchId   Int?
  question  String
  options   String   @default("[]")  // JSON: ["Home wins","Draw","Away wins"]
  status    String   @default("open") // "open" | "closed"
  createdAt DateTime @default(now())

  match     Match?     @relation(fields: [matchId], references: [id], onDelete: SetNull)
  votes     PollVote[]
}

model PollVote {
  id        Int      @id @default(autoincrement())
  pollId    Int
  userId    String
  option    String
  createdAt DateTime @default(now())

  poll      Poll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
}

// ─── Audit Log ─────────────────────────────────────────────

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    String
  action    String   // "predict", "update_prediction", "login", "register", etc.
  details   String   @default("") // JSON or human-readable info
  ip        String   @default("")
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Shoutbox ──────────────────────────────────────────────

model ShoutboxMessage {
  id        Int      @id @default(autoincrement())
  userId    String?
  guestName String   @default("Guest")
  message   String
  ip        String   @default("")
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ─── Site Settings ─────────────────────────────────────────

model Setting {
  key   String @id
  value String
}
